  "agent_frameworks": [
    {
      "id": "hermes-agent",
      "name": "Hermes Agent",
      "provider": "Nous Research",
      "icon": "🪽",
      "status": "coming_soon",
      "privacy": "self_hosted",
      "role": "gate_1_operator",
      "description": "The autonomous agent layer beside Shon. Reviews every proposed action, checks safety and privacy, checks past decisions, assigns risk level, then asks Shon for one-tap approval.",
      "install": "curl -fsSL https://hermes-agent.nousresearch.com/install.sh | bash && hermes setup",
      "mission_vault_role": [
        "Gate 1 review layer — human-in-the-loop",
        "Checks data privacy before any action",
        "Checks model permission against source",
        "Checks contradiction with past decisions in RAG",
        "Assigns risk level to every proposed action",
        "Presents approve/reject/ask-more to Shon",
        "Scheduled automations in natural language",
        "Persistent memory across sessions",
        "Skill creation and growth",
        "Telegram, WhatsApp, Slack, Email control",
        "Sub-agent delegation for parallel work"
      ],
      "gate_responsibilities": [
        "review proposed actions before execution",
        "check data privacy rules",
        "check model permission against source privacy",
        "check contradiction with past RAG decisions",
        "assign risk level: low/medium/high/blocked",
        "present one clear decision to Shon"
      ]
    }
  ],
