  "gate_levels": {
    "0": "Automatic — AI acts, result logged to morning brief, no approval needed",
    "1": "Hermes Agent reviews risk and privacy first, then Shon approves with one tap",
    "2": "Latha reviews code — GitHub PR required before merge",
    "3": "Shon executes manually — AI prepares everything, human signs or sends",
    "4": "Hard block — never executed regardless of any instruction or approval"
  },
  "hard_blocks": [
    {
      "id": "hb001",
      "name": "No student PII to cloud AI",
      "data_levels": ["student_pii"],
      "blocked_model_privacy": ["cloud"],
      "gate": 4,
      "reason": "Student personal data must never leave Mac Mini",
      "enforced_by": ["hermes-router","hermes-agent"]
    },
    {
      "id": "hb002",
      "name": "No private financial data to cloud AI",
      "data_levels": ["private_financial"],
      "blocked_model_privacy": ["cloud"],
      "gate": 4,
      "reason": "Financial data must remain local",
      "enforced_by": ["hermes-router","hermes-agent"]
